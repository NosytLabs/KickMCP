{
  "name": "kick-mcp",
  "version": "1.0.0",
  "private": false,
  "description": "Unofficial MCP server for the official Kick.com public API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NosytLabs/KickMCP.git"
  },
  "bugs": {
    "url": "https://github.com/NosytLabs/KickMCP/issues"
  },
  "homepage": "https://github.com/NosytLabs/KickMCP#readme",
  "type": "module",
  "bin": {
    "kick-mcp": "./dist/stdio.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "SKILL.md",
    "LICENSE",
    "server.json",
    ".env.example"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:stdio": "node dist/stdio.js",
    "prepack": "npm run build",
    "pack:check": "npm run build && node scripts/check-pack.mjs",
    "live:read": "npm run build && node scripts/live-read-examples.mjs",
    "smoke": "npm run build && node scripts/smoke-test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "kick",
    "kick.com",
    "mcp",
    "model-context-protocol",
    "streaming",
    "moderation",
    "webhooks"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
